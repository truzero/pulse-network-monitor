/target/
Cargo.lock
!/src-tauri/Cargo.lock

# Cargo when part of a workspace root you may want to commit; uncomment if this is a leaf crate only
# Cargo.lock

# Rust / rustfmt / clippy backups
**/*.rs.bk
*.pdb

# IDE and OS
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Environment and secrets
.env
.env.*
!.env.example

# Tauri / front-end build artifacts (when present)
dist/
dist-ssr/
*.local

# Node (if using a JS/TS frontend)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Logs and temp
*.log
tmp/
temp/

# Local junk (never commit nested git dirs)
.git.old.*/

# Private developer-local overlays (keep out of forks and CI sandboxes)
_vendor/
cursorignore.template
.cursorignore
